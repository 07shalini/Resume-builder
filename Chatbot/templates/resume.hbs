<html>
  <head>
    <meta charset="UTF-8" />
    <title>{{personalInfo.fullName}} - Resume</title>
    <style>
      body {
        font-family: 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        max-width: 800px;
        margin: 0 auto;
        padding: 40px;
        color: #333;
      }
      
      .header {
        text-align: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #3498db;
        padding-bottom: 20px;
      }
      
      .header h1 {
        color: #2c3e50;
        margin-bottom: 10px;
        font-size: 2.5em;
      }
      
      .header .title {
        color: #7f8c8d;
        font-size: 1.2em;
        margin-bottom: 15px;
      }
      
      .contact-info {
        color: #7f8c8d;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 20px;
      }
      
      .contact-info span {
        display: flex;
        align-items: center;
        gap: 5px;
      }
      
      .section {
        margin-bottom: 25px;
      }
      
      h2 {
        color: #34495e;
        border-bottom: 2px solid #3498db;
        padding-bottom: 5px;
        margin-bottom: 15px;
      }
      
      .skills-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
      }
      
      .skill-item {
        background-color: #f0f0f0;
        padding: 5px 15px;
        border-radius: 15px;
        font-size: 0.9em;
        color: #2c3e50;
      }
      
      .experience-item, .education-item, .certification-item, .project-item, .award-item {
        margin-bottom: 20px;
      }
      
      .experience-item h3, .education-item h3 {
        color: #2c3e50;
        margin-bottom: 5px;
      }
      
      .experience-duration, .education-year {
        color: #7f8c8d;
        font-size: 0.9em;
        margin-bottom: 5px;
      }
      
      .languages-list {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
      }
      
      .language-item {
        background-color: #f8f9fa;
        padding: 8px 15px;
        border-radius: 5px;
        font-size: 0.9em;
      }
      
      .project-technologies {
        color: #7f8c8d;
        font-size: 0.9em;
        margin-top: 5px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>{{personalInfo.fullName}}</h1>
      <div class="title">{{personalInfo.title}}</div>
      <div class="contact-info">
        <span>📧 {{contact.email}}</span>
        {{#if contact.phone}}
        <span>📱 {{contact.phone}}</span>
        {{/if}}
        {{#if contact.location}}
        <span>📍 {{contact.location}}</span>
        {{/if}}
        {{#if contact.linkedin}}
        <span>🔗 <a href="{{contact.linkedin}}" target="_blank">LinkedIn</a></span>
        {{/if}}
      </div>
    </div>

    {{#if professionalSummary}}
    <div class="section">
      <h2>Professional Summary</h2>
      <p>{{professionalSummary}}</p>
    </div>
    {{/if}}

    {{#if skills.length}}
    <div class="section">
      <h2>Skills</h2>
      <div class="skills-list">
        {{#each skills}}
          <span class="skill-item">{{this}}</span>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if workExperience.length}}
    <div class="section">
      <h2>Work Experience</h2>
      {{#each workExperience}}
        <div class="experience-item">
          <h3>{{position}} at {{company}}</h3>
          <div class="experience-duration">{{duration}}</div>
          <p>{{responsibilities}}</p>
        </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if education.length}}
    <div class="section">
      <h2>Education</h2>
      {{#each education}}
        <div class="education-item">
          <h3>{{degree}}</h3>
          <div class="education-year">{{institution}} | {{year}}{{#if gpa}} | GPA: {{gpa}}{{/if}}</div>
        </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if certifications.length}}
    <div class="section">
      <h2>Certifications</h2>
      {{#each certifications}}
        <div class="certification-item">
          <strong>{{name}}</strong> - {{organization}} ({{year}})
        </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if languages.length}}
    <div class="section">
      <h2>Languages</h2>
      <div class="languages-list">
        {{#each languages}}
          <div class="language-item">
            <strong>{{language}}</strong> - {{proficiency}}
          </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if projects.length}}
    <div class="section">
      <h2>Notable Projects</h2>
      {{#each projects}}
        <div class="project-item">
          <h3>{{name}}</h3>
          <p>{{description}}</p>
          <div class="project-technologies">Technologies: {{technologies}}</div>
        </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if awards.length}}
    <div class="section">
      <h2>Awards & Achievements</h2>
      {{#each awards}}
        <div class="award-item">
          <strong>{{name}}</strong> - {{organization}} ({{year}})
        </div>
      {{/each}}
    </div>
    {{/if}}
  </body>
</html>
</html>